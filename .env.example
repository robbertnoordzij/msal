# Azure AD Configuration
# Copy this file to .env and fill in your values from Azure AD App Registration

# Your Azure AD Application (Client) ID
AZURE_CLIENT_ID=your-client-id-here

# Your Azure AD Directory (Tenant) ID
AZURE_TENANT_ID=your-tenant-id-here

# Optional: Client Secret (only needed for backend-to-backend auth, not for this BFF pattern)
AZURE_CLIENT_SECRET=your-client-secret-here

# ─── Azure AD Credential ─────────────────────────────────────────────────────
# How the backend authenticates against Azure AD to exchange tokens.
#
#   secret           (default) — plain client secret; requires AZURE_CLIENT_SECRET above.
#   managed-identity           — uses the Managed Identity assigned to the Azure compute
#                                resource (App Service, AKS, Container Apps, VM …).
#                                No secret needed. Requires a Federated Identity Credential
#                                on the app registration (Azure Portal one-time step).
#
AZURE_CREDENTIAL_TYPE=secret

# User-assigned Managed Identity client ID — only when AZURE_CREDENTIAL_TYPE=managed-identity
# Leave empty to use the system-assigned Managed Identity.
AZURE_MANAGED_IDENTITY_CLIENT_ID=

# Application URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8080

# Backend Configuration
BACKEND_PORT=8080
BACKEND_CONTEXT_PATH=/api

# Cookie Settings
COOKIE_NAME=AUTH_TOKEN
REFRESH_TOKEN_COOKIE_NAME=REFRESH_TOKEN
COOKIE_MAX_AGE=3600
REFRESH_TOKEN_MAX_AGE=86400
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax

# ─── MSAL Token Cache ────────────────────────────────────────────────────────
# Choose where MSAL refresh tokens are stored server-side.
#
#   redis  (default) — shared across all backend replicas; requires Redis.
#   cookie           — encrypted HttpOnly cookie; no infrastructure needed,
#                      but not suitable for horizontally-scaled deployments.
#
TOKEN_CACHE_TYPE=redis

# Cookie cache settings (only used when TOKEN_CACHE_TYPE=cookie)
# REQUIRED when TOKEN_CACHE_TYPE=cookie. Generate with: openssl rand -base64 32
TOKEN_CACHE_COOKIE_ENCRYPTION_KEY=
# Set to false only for local HTTP development (cookie requires HTTPS in prod)
TOKEN_CACHE_COOKIE_SECURE=false

# Redis — distributed MSAL token cache (shared across all backend instances)
# The docker-compose.yml starts a local Redis instance on port 6379.
# Only needed when TOKEN_CACHE_TYPE=redis.
REDIS_HOST=localhost
REDIS_PORT=6379
# REQUIRED: set a strong password in all environments (dev fallback: changeme-in-dev)
REDIS_PASSWORD=changeme-in-dev
# Enable TLS — set to true for Azure Cache for Redis (port 6380)
REDIS_TLS=false
# Token cache TTL (Spring Duration format: "90d", "24h", "3600s"). Default: 90 days.
REDIS_TTL=90d
# AES-256-GCM encryption key for token cache at rest.
# REQUIRED in non-local environments. Generate with: openssl rand -base64 32
# Leaving this empty is only acceptable for local development (warning will be logged).
REDIS_ENCRYPTION_KEY=

# Logging Level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=DEBUG
