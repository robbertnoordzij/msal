# Node modules — covers frontend/, e2e/, and any future JS packages
**/node_modules/
frontend/.env.local
frontend/build/

# Auto-generated configuration files (contain secrets — generated by configure.sh/.ps1)
frontend/src/config/msalConfig.js
backend/src/main/resources/application.properties
backend/target/classes/application.properties
out/

# Maven
backend/target/
backend/.mvn/
backend/mvnw
backend/mvnw.cmd

# IDE files
.vscode/
.idea/
*.iml
*.iws
*.ipr

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Environment / secrets — never commit these
.env
.env.local
.env.development
.env.production
!.env.example

# Playwright test artifacts
e2e/test-results/
e2e/playwright-report/

# Java
*.class
*.jar
!maven-wrapper.jar

# Spring Boot
BOOT-INF/